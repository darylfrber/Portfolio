{% extends "layouts/app.twig" %}


{% block title %}
	Home
{% endblock %}

{% block body %}
	<section class="grid gap-6 lg:grid-cols-[1.45fr_1fr]">
		<div class="panel panel-premium p-6 sm:p-8">
			<p class="mb-4 inline-flex items-center rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-1 text-sm text-cyan-200">
				Full-stack developer
			</p>
			<h1 class="mb-4 text-3xl font-bold tracking-tight text-white sm:text-5xl">
				Hoi, ik ben Daryl. Ik bouw graag dingen waar mensen echt iets aan hebben.
			</h1>
			<p class="mb-6 max-w-2xl text-slate-300">
				Via stages ben ik doorgegroeid naar vaste rollen bij Minty Media en Accuselect. Daar werk ik dagelijks aan Laravel/React projecten, van dashboards voor thuisbatterijen tot mobiele apps en API-koppelingen.
			</p>
			<div class="grid gap-4 sm:grid-cols-2">
				<div class="rounded-xl border border-slate-700/60 bg-slate-900/70 p-4">
					<p class="text-xs uppercase tracking-wide text-slate-400">Nu</p>
					<p class="mt-2 text-sm text-slate-200">Full-Stack Developer bij Accuselect (2025 - heden)</p>
				</div>
				<div class="rounded-xl border border-slate-700/60 bg-slate-900/70 p-4">
					<p class="text-xs uppercase tracking-wide text-slate-400">Wat ik belangrijk vind</p>
					<p class="mt-2 text-sm text-slate-200">Samenwerken, nieuwe features bouwen, clean code en blijven leren.</p>
				</div>
			</div>
			<div class="mt-5 border-t border-slate-700/50 pt-5">
				<p class="text-xs uppercase tracking-wide text-slate-500">Dagelijkse stack</p>
				<p class="skill-tags-plain mt-2 text-sm text-slate-400">
					<span>PHP</span><span class="skill-tags-sep">·</span><span>Laravel</span><span class="skill-tags-sep">·</span><span>React</span><span class="skill-tags-sep">·</span><span>JavaScript</span><span class="skill-tags-sep">·</span><span>TypeScript</span><span class="skill-tags-sep">·</span><span>HTML</span><span class="skill-tags-sep">·</span><span>CSS</span><span class="skill-tags-sep">·</span><span>Python (lerend)</span>
				</p>
			</div>
			<div class="mt-7 flex flex-wrap gap-3">
				<a href="/projects" class="inline-flex items-center gap-2 rounded-xl bg-cyan-500 px-4 py-2 font-medium text-slate-950 transition hover:bg-cyan-400">
					<i class="fa-solid fa-diagram-project"></i>
					Bekijk mijn projecten
				</a>
				<a href="/contact" class="inline-flex items-center gap-2 rounded-xl border border-cyan-400/50 bg-cyan-400/10 px-4 py-2 font-medium text-cyan-100 transition hover:border-cyan-300 hover:bg-cyan-300/20">
					<i class="fa-solid fa-paper-plane"></i>
					Start een gesprek
				</a>
				<a href="https://github.com/darylfrber" target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 rounded-xl border border-slate-600 px-4 py-2 font-medium text-slate-100 transition hover:border-slate-400 hover:bg-slate-900/80">
					<i class="fa-brands fa-github"></i>
					GitHub profiel
				</a>
			</div>
		</div>
		<aside class="panel p-6">
			<img src="./assets/images/me.png" alt="Foto van Daryl Färber" class="mx-auto mb-5 h-32 w-32 rounded-2xl border border-slate-700 object-cover">
			<h2 class="text-center text-xl font-semibold text-white">Daryl Färber</h2>
			<p class="mt-2 text-center text-sm text-slate-400">Full-Stack Developer</p>
			<ul class="mt-5 space-y-3 text-sm text-slate-300">
				<li class="flex items-center gap-3"><i class="fa-solid fa-location-dot text-cyan-300"></i>Purmerend, Noord-Holland</li>
				<li class="flex items-center gap-3"><i class="fa-solid fa-envelope text-cyan-300"></i>darylfarber@gmail.com</li>
				<li class="flex items-center gap-3"><i class="fa-solid fa-phone text-cyan-300"></i>+31 6 53917126</li>
				<li class="flex items-center gap-3"><i class="fa-brands fa-linkedin text-cyan-300"></i>linkedin.com/in/daryl-farber</li>
			</ul>
		</aside>
	</section>

	<section class="mt-8 grid gap-4 md:grid-cols-3">
		<article class="value-card">
			<i class="fa-solid fa-bolt text-cyan-300"></i>
			<h3 class="mt-3 text-lg font-semibold text-white">Van stage naar vaste rol</h3>
			<p class="mt-2 text-sm text-slate-300">Ik ben gestart als stagiair en doorgegroeid naar vaste functies. Dat zegt veel over mijn inzet en leergierigheid.</p>
		</article>
		<article class="value-card">
			<i class="fa-solid fa-layer-group text-cyan-300"></i>
			<h3 class="mt-3 text-lg font-semibold text-white">Brede praktijkervaring</h3>
			<p class="mt-2 text-sm text-slate-300">Van WordPress plugins en REST API's tot Laravel dashboards, React Native apps en nu ook Python erbij leren.</p>
		</article>
		<article class="value-card">
			<i class="fa-solid fa-people-group text-cyan-300"></i>
			<h3 class="mt-3 text-lg font-semibold text-white">Persoonlijke manier van werken</h3>
			<p class="mt-2 text-sm text-slate-300">Gestructureerd, teamgericht en altijd bezig om code beter en duidelijker te maken.</p>
		</article>
	</section>

	<section class="mt-8 panel p-6 sm:p-8">
		<div class="flex flex-col items-start justify-between gap-5 lg:flex-row lg:items-center">
			<div>
				<h2 class="text-2xl font-semibold text-white">Lijkt het je leuk om samen iets te bouwen?</h2>
				<p class="mt-2 max-w-2xl text-slate-300">Stuur gerust een bericht. Ik denk graag mee, ook als je nog niet precies weet wat je nodig hebt.</p>
			</div>
			<a href="/contact" class="inline-flex items-center gap-2 rounded-xl bg-white px-4 py-2 font-semibold text-slate-900 transition hover:bg-slate-200">
				<i class="fa-solid fa-comments"></i>
				Neem contact op
			</a>
		</div>
	</section>
{% endblock %}