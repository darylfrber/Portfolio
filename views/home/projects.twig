{% extends "layouts/app.twig" %}


{% block title %}
	Projects
{% endblock %}

{% block body %}
	<section class="mb-8 panel p-6 sm:p-8">
		<h2 class="mb-3 text-2xl font-semibold text-white">Projecten & focus</h2>
		<p class="max-w-4xl text-slate-300">
			Hier vind je een selectie van projecten waarin ik vooral heb gewerkt met PHP/Laravel, JavaScript, React en API-koppelingen. In mijn dagelijkse werk ligt de nadruk op stabiele back-end oplossingen, duidelijke UX en schaalbare featureontwikkeling.
		</p>
		<div class="mt-4 flex flex-wrap gap-2">
			<span class="rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-1 text-xs text-cyan-200">PHP</span>
			<span class="rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-1 text-xs text-cyan-200">Laravel</span>
			<span class="rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-1 text-xs text-cyan-200">React</span>
			<span class="rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-1 text-xs text-cyan-200">TypeScript</span>
			<span class="rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-1 text-xs text-cyan-200">Docker</span>
		</div>
		<div class="mt-5 flex flex-wrap gap-3">
			<a href="https://github.com/darylfrber" target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 rounded-xl bg-white px-4 py-2 font-medium text-slate-900 transition hover:bg-slate-200">
				<i class="fa-brands fa-github"></i>
				Meer code op GitHub
			</a>
			<a href="/contact" class="inline-flex items-center gap-2 rounded-xl border border-slate-600 px-4 py-2 font-medium text-slate-100 transition hover:border-slate-400 hover:bg-slate-900/70">
				<i class="fa-solid fa-paper-plane"></i>
				Samenwerken?
			</a>
		</div>
	</section>

	<section class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
		<article class="project-card">
			<div class="project-media">
				<img src="assets/images/promptbook.png" alt="Promptbook screenshot" class="project-image">
			</div>
			<div class="p-5">
				<h3 class="mb-2 text-xl font-semibold text-white">Promptbook</h3>
				<p class="mb-4 text-sm text-slate-300">Laravel + React project voor het opslaan en beheren van AI prompts met focus op snelheid en overzicht.</p>
				<a href="https://promptbook.darylfarber.nl" target="_blank" rel="noreferrer" class="project-link">Bekijk project</a>
			</div>
		</article>

		<article class="project-card">
			<div class="project-media">
				<img src="assets/images/staynotified.png" alt="StayNotified screenshot" class="project-image">
			</div>
			<div class="p-5">
				<h3 class="mb-2 text-xl font-semibold text-white">StayNotified</h3>
				<p class="mb-4 text-sm text-slate-300">Persoonlijk platform met kalender- en notitiefunctionaliteit, ontworpen voor eenvoud en dagelijks gebruik.</p>
				<a href="https://staynotified.darylfarber.nl" target="_blank" rel="noreferrer" class="project-link">Bekijk project</a>
			</div>
		</article>

		<article class="project-card">
			<div class="project-media">
				<img src="assets/images/binsta.png" alt="Binsta screenshot" class="project-image">
			</div>
			<div class="p-5">
				<h3 class="mb-2 text-xl font-semibold text-white">Binsta</h3>
				<p class="mb-4 text-sm text-slate-300">Social coding platform waar gebruikers code kunnen delen, bespreken en verbeteren met elkaar.</p>
				<a href="https://binsta.darylfarber.nl" target="_blank" rel="noreferrer" class="project-link">Bekijk project</a>
			</div>
		</article>

		<article class="project-card">
			<div class="project-media">
				<img src="assets/images/spacex.png" alt="SpaceX screenshot" class="project-image">
			</div>
			<div class="p-5">
				<h3 class="mb-2 text-xl font-semibold text-white">SpaceX</h3>
				<p class="mb-4 text-sm text-slate-300">Teamproject met een data-gedreven front-end rondom SpaceX informatie en missie-overzichten.</p>
				<a href="https://spacex.darylfarber.nl" target="_blank" rel="noreferrer" class="project-link">Bekijk project</a>
			</div>
		</article>

		<article class="project-card">
			<div class="project-media">
				<img src="assets/images/webshop.png" alt="Webshop screenshot" class="project-image">
			</div>
			<div class="p-5">
				<h3 class="mb-2 text-xl font-semibold text-white">Webshop</h3>
				<p class="mb-4 text-sm text-slate-300">Eindopdracht voor e-commerce met aandacht voor UI-flow, productoverzicht en eenvoudige checkout.</p>
				<a href="https://webshop.darylfarber.nl" target="_blank" rel="noreferrer" class="project-link">Bekijk project</a>
			</div>
		</article>

		<article class="project-card">
			<div class="project-media">
				<img src="assets/images/westworld.png" alt="Westworld screenshot" class="project-image">
			</div>
			<div class="p-5">
				<h3 class="mb-2 text-xl font-semibold text-white">Westworld</h3>
				<p class="mb-4 text-sm text-slate-300">Groepsproject waarin samenwerking, planning en consistente code-architectuur centraal stonden.</p>
				<a href="https://westworld.darylfarber.nl" target="_blank" rel="noreferrer" class="project-link">Bekijk project</a>
			</div>
		</article>
	</section>
{% endblock %}