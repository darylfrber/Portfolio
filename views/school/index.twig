{% extends "layouts/app.twig" %}


{% block title %}
	School
{% endblock %}

{% block body %}
	<section class="grid gap-6 lg:grid-cols-2">
		<div class="panel p-6">
			<h3 class="mb-4 text-xl font-semibold text-white">Laatste activiteiten</h3>
			<div class="space-y-3">
				{% if projectData is iterable %}
					{% for data in projectData %}
						{% set eventDateTime = data.event.created_at|date("Y-m-d H:i:s") %}
						{% set currentDateTime = "now"|date("Y-m-d H:i:s") %}
						{% set eventTime = date(eventDateTime) %}
						{% set currentTime = date(currentDateTime) %}
						{% set timeDiff = currentTime.diff(eventTime) %}
						{% set formattedTimeDiff = "" %}

						{% if timeDiff.years %}
							{% set formattedTimeDiff = timeDiff.years ~ " jaar" ~ (timeDiff.years > 1 ? "s" : "") ~ " geleden" %}
						{% elseif timeDiff.months %}
							{% set formattedTimeDiff = timeDiff.months ~ " maand" ~ (timeDiff.months > 1 ? "s" : "") ~ " geleden" %}
						{% elseif timeDiff.days %}
							{% set formattedTimeDiff = timeDiff.days ~ " dag" ~ (timeDiff.days > 1 ? "en" : "") ~ " geleden" %}
						{% elseif timeDiff.h %}
							{% set formattedTimeDiff = timeDiff.h ~ " uur geleden" %}
						{% elseif timeDiff.i %}
							{% set formattedTimeDiff = timeDiff.i ~ " minuten geleden" %}
						{% else %}
							{% set formattedTimeDiff = "Zojuist" %}
						{% endif %}

						<div class="rounded-xl border border-slate-700/60 bg-slate-900/70 p-3">
							<div class="flex items-start gap-3">
								<img src="{{ data.event.author.avatar_url }}" alt="Avatar" class="h-10 w-10 rounded-full border border-slate-700 object-cover">
								<div class="min-w-0 flex-1">
									<a href="{{ data.project.web_url }}" target="_blank" rel="noreferrer" class="block truncate text-sm font-semibold text-cyan-300 hover:text-cyan-200">{{ data.project.name_with_namespace }}</a>
									<p class="mt-1 truncate text-sm text-slate-300">{{ data.event.push_data.commit_title }}</p>
								</div>
								<span class="whitespace-nowrap text-xs text-slate-500">{{ formattedTimeDiff }}</span>
							</div>
						</div>
					{% endfor %}
				{% else %}
					<p class="text-slate-400">{{ projectData }}</p>
				{% endif %}
			</div>
		</div>
		<div class="panel p-6">
			<h3 class="mb-4 text-xl font-semibold text-white">Schoolverkenner</h3>
			<div id="folderStructure" class="space-y-2"></div>
		</div>
	</section>
{% endblock %}