{% extends "layouts/app.twig" %}


{% block title %}
	Contact
{% endblock %}

{% block body %}
	<section class="mb-8 panel p-6 sm:p-8">
		<div class="flex flex-col gap-6 sm:flex-row sm:items-center">
			<img src="./assets/images/me.png" alt="Foto van Daryl Färber" class="h-28 w-28 rounded-2xl border border-slate-700 object-cover">
			<div>
				<h2 class="text-2xl font-semibold text-white">Contact & samenwerken</h2>
				<p class="mt-2 text-slate-300">Interesse in samenwerking of een idee? We kunnen altijd vrijblijvend over de mogelijkheden sparren.</p>
				<p class="mt-3 text-sm text-slate-400">Purmerend, Noord-Holland, Nederland</p>
			</div>
		</div>
	</section>

	<section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
		<a href="mailto:darylfarber@gmail.com" class="contact-card">
			<i class="fa-solid fa-envelope text-xl text-cyan-300"></i>
			<h3 class="mt-3 font-semibold text-white">E-mail</h3>
			<p class="mt-1 text-sm text-slate-300">darylfarber@gmail.com</p>
		</a>

		<a href="tel:+31653917126" class="contact-card">
			<i class="fa-solid fa-phone text-xl text-cyan-300"></i>
			<h3 class="mt-3 font-semibold text-white">Telefoon</h3>
			<p class="mt-1 text-sm text-slate-300">+31 6 53917126</p>
		</a>

		<a href="https://github.com/darylfrber" target="_blank" rel="noreferrer" class="contact-card">
			<i class="fa-brands fa-github text-xl text-cyan-300"></i>
			<h3 class="mt-3 font-semibold text-white">GitHub</h3>
			<p class="mt-1 text-sm text-slate-300">github.com/darylfrber</p>
		</a>

		<a href="https://www.linkedin.com/in/daryl-farber" target="_blank" rel="noreferrer" class="contact-card">
			<i class="fa-brands fa-linkedin text-xl text-cyan-300"></i>
			<h3 class="mt-3 font-semibold text-white">LinkedIn</h3>
			<p class="mt-1 text-sm text-slate-300">linkedin.com/in/daryl-farber</p>
		</a>
	</section>

	<section class="mt-8 panel p-6">
		<h3 class="text-xl font-semibold text-white">GitHub eerst</h3>
		<p class="mt-2 text-slate-300">
			Ik deel actief code, experimenten en project-updates op GitHub. Daar krijg je het beste beeld van mijn huidige ontwikkelstijl, architectuurkeuzes en technische groei.
		</p>
		<a href="https://github.com/darylfrber" target="_blank" rel="noreferrer" class="mt-4 inline-flex items-center gap-2 rounded-xl bg-cyan-500 px-4 py-2 font-medium text-slate-950 transition hover:bg-cyan-400">
			<i class="fa-brands fa-github"></i>
			Ga naar GitHub
		</a>
	</section>
{% endblock %}