{% extends "layouts/app.twig" %}

{% block title %}
	404
{% endblock %}

{% block controller %}
	Error
{% endblock %}

{% block body %}
	<div class="mx-auto mt-8 max-w-2xl rounded-2xl border border-red-400/30 bg-red-500/10 p-6 text-red-100">
		<h2 class="text-2xl font-semibold">Error {{ errorNumber }}</h2>
		<p class="mt-2 text-sm text-red-100/90">{{ errorMessage }}</p>
	</div>
{% endblock %}