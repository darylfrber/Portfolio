{% extends "layouts/app.twig" %}


{% block title %}
	Projects
{% endblock %}

{% block body %}
	<section class="mb-8">
		<div class="panel p-6 sm:p-8">
			<h2 class="mb-3 text-2xl font-semibold text-white">Projecten & focus</h2>
			<p class="max-w-4xl text-slate-300">
				Deze projecten laten goed zien waar ik energie van krijg: nieuwe dingen bouwen, experimenteren en steeds beter worden als developer. Veel van deze projecten zijn ontstaan vanuit school, werk of eigen interesse.
			</p>
		</div>
		<div class="mt-4 border-t border-slate-800/80 pt-4">
			<p class="text-xs uppercase tracking-wide text-slate-500">Vaak gebruikt in deze projecten</p>
			<p class="skill-tags-plain mt-2 text-sm text-slate-400">
				<span>PHP</span><span class="skill-tags-sep">·</span><span>Laravel</span><span class="skill-tags-sep">·</span><span>React</span><span class="skill-tags-sep">·</span><span>JavaScript</span><span class="skill-tags-sep">·</span><span>TypeScript</span><span class="skill-tags-sep">·</span><span>HTML</span><span class="skill-tags-sep">·</span><span>CSS</span><span class="skill-tags-sep">·</span><span>Docker</span>
			</p>
		</div>
		<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
			<a href="https://github.com/darylfrber" target="_blank" rel="noreferrer" class="inline-flex min-h-[44px] w-full items-center justify-center gap-2 rounded-xl bg-white px-4 py-2.5 text-center font-medium text-slate-900 transition hover:bg-slate-200 sm:w-auto">
				<i class="fa-brands fa-github"></i>
				Meer code op GitHub
			</a>
			<a href="/contact" class="inline-flex min-h-[44px] w-full items-center justify-center gap-2 rounded-xl border border-slate-600 px-4 py-2.5 text-center font-medium text-slate-100 transition hover:border-slate-400 hover:bg-slate-900/70 sm:w-auto">
				<i class="fa-solid fa-paper-plane"></i>
				Samenwerken?
			</a>
		</div>
	</section>

	<section class="mb-8 grid gap-4 lg:grid-cols-2">
		<div class="panel p-6">
			<p class="text-xs uppercase tracking-wide text-cyan-300">Achtergrond</p>
			<h3 class="mt-2 text-2xl font-semibold text-white">Hoe ik ben gegroeid als developer</h3>
			<ul class="mt-4 space-y-3 text-sm text-slate-300">
				<li class="flex items-start gap-3"><i class="fa-solid fa-check mt-1 text-cyan-300"></i><span>Bit-Academy afgerond (Software Ontwikkelaar MBO 4).</span></li>
				<li class="flex items-start gap-3"><i class="fa-solid fa-check mt-1 text-cyan-300"></i><span>Van stage bij Minty Media naar parttime back-end werk tijdens m'n studie.</span></li>
				<li class="flex items-start gap-3"><i class="fa-solid fa-check mt-1 text-cyan-300"></i><span>Bij Accuselect gestart als stagiair en na mijn stage fulltime blijven werken als full-stack developer.</span></li>
			</ul>
		</div>
		<div class="panel panel-premium p-6">
			<p class="text-xs uppercase tracking-wide text-cyan-300">Persoonlijk</p>
			<h3 class="mt-2 text-2xl font-semibold text-white">Waarom GitHub belangrijk voor mij is</h3>
			<p class="mt-3 text-sm text-slate-300">Op GitHub houd ik mijn voortgang bij, test ik nieuwe ideeën en deel ik projecten waar ik trots op ben. Dat is voor mij de plek waar leren en bouwen samenkomen.</p>
			<a href="https://github.com/darylfrber" target="_blank" rel="noreferrer" class="mt-5 inline-flex items-center gap-2 rounded-xl border border-cyan-400/50 bg-cyan-400/10 px-4 py-2 font-medium text-cyan-100 transition hover:border-cyan-300 hover:bg-cyan-300/20">
				<i class="fa-brands fa-github"></i>
				Bekijk mijn GitHub
			</a>
		</div>
	</section>

	<section class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
		<article class="project-card">
			<div class="project-media">
				<img src="assets/images/promptbook.png" alt="Promptbook screenshot" class="project-image">
			</div>
			<div class="p-5">
				<h3 class="mb-2 text-xl font-semibold text-white">Promptbook</h3>
				<p class="mb-4 text-sm text-slate-300">Laravel + React project voor het opslaan en beheren van AI prompts met focus op snelheid en overzicht.</p>
				<a href="https://promptbook.darylfarber.nl" target="_blank" rel="noreferrer" class="project-link">Bekijk project</a>
			</div>
		</article>

		<article class="project-card">
			<div class="project-media">
				<img src="assets/images/staynotified.png" alt="StayNotified screenshot" class="project-image">
			</div>
			<div class="p-5">
				<h3 class="mb-2 text-xl font-semibold text-white">StayNotified</h3>
				<p class="mb-4 text-sm text-slate-300">Persoonlijk platform met kalender- en notitiefunctionaliteit, ontworpen voor eenvoud en dagelijks gebruik.</p>
				<a href="https://staynotified.darylfarber.nl" target="_blank" rel="noreferrer" class="project-link">Bekijk project</a>
			</div>
		</article>

		<article class="project-card">
			<div class="project-media">
				<img src="assets/images/binsta.png" alt="Binsta screenshot" class="project-image">
			</div>
			<div class="p-5">
				<h3 class="mb-2 text-xl font-semibold text-white">Binsta</h3>
				<p class="mb-4 text-sm text-slate-300">Social coding platform waar gebruikers code kunnen delen, bespreken en verbeteren met elkaar.</p>
				<a href="https://binsta.darylfarber.nl" target="_blank" rel="noreferrer" class="project-link">Bekijk project</a>
			</div>
		</article>

		<article class="project-card">
			<div class="project-media">
				<img src="assets/images/spacex.png" alt="SpaceX screenshot" class="project-image">
			</div>
			<div class="p-5">
				<h3 class="mb-2 text-xl font-semibold text-white">SpaceX</h3>
				<p class="mb-4 text-sm text-slate-300">Teamproject met een data-gedreven front-end rondom SpaceX informatie en missie-overzichten.</p>
				<a href="https://spacex.darylfarber.nl" target="_blank" rel="noreferrer" class="project-link">Bekijk project</a>
			</div>
		</article>

		<article class="project-card">
			<div class="project-media">
				<img src="assets/images/webshop.png" alt="Webshop screenshot" class="project-image">
			</div>
			<div class="p-5">
				<h3 class="mb-2 text-xl font-semibold text-white">Webshop</h3>
				<p class="mb-4 text-sm text-slate-300">Eindopdracht voor e-commerce met aandacht voor UI-flow, productoverzicht en eenvoudige checkout.</p>
				<a href="https://webshop.darylfarber.nl" target="_blank" rel="noreferrer" class="project-link">Bekijk project</a>
			</div>
		</article>

		<article class="project-card">
			<div class="project-media">
				<img src="assets/images/westworld.png" alt="Westworld screenshot" class="project-image">
			</div>
			<div class="p-5">
				<h3 class="mb-2 text-xl font-semibold text-white">Westworld</h3>
				<p class="mb-4 text-sm text-slate-300">Groepsproject waarin samenwerking, planning en consistente code-architectuur centraal stonden.</p>
				<a href="https://westworld.darylfarber.nl" target="_blank" rel="noreferrer" class="project-link">Bekijk project</a>
			</div>
		</article>
	</section>
{% endblock %}