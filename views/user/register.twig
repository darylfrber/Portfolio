{% extends "layouts/app.twig" %}


{% block title %}
	Registreren
{% endblock %}

{% block body %}
	<section class="mx-auto mt-10 max-w-xl panel p-6 sm:p-8">
		<form id="loginForm">
			<div class="mb-6 flex items-center justify-between">
				<h1 class="text-2xl font-semibold text-white">Registreren</h1>
				<i class="fa-solid fa-user-plus text-xl text-cyan-300"></i>
			</div>
			<div class="space-y-4">
				<input id="username" type="text" name="username" class="input-modern" placeholder="Gebruikersnaam"/>
				<input id="password" type="password" name="password" class="input-modern" placeholder="Wachtwoord"/>
				<input id="confirm_password" type="password" name="confirm_password" class="input-modern" placeholder="Herhaal wachtwoord"/>
			</div>
			<button type="submit" class="mt-5 inline-flex w-full items-center justify-center rounded-xl bg-cyan-500 px-4 py-2.5 font-medium text-slate-950 transition hover:bg-cyan-400">Creëer je account</button>
		</form>
		<p class="mt-5 text-sm text-slate-400">Al een account? <a href="/login" class="text-cyan-300 hover:text-cyan-200">Log in</a></p>
	</section>
	<script src="assets/js/register.js"></script>
{% endblock %}