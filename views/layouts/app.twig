<!DOCTYPE html>
<html lang="en">
	<head>
		{% block head %}
			<meta charset="UTF-8">
			<meta http-equiv="X-UA-Compatible" content="IE=edge">
			<meta name="viewport" content="width=device-width, initial-scale=1.0">
			<meta name="description" content="Portfolio van Daryl Farber">
			<meta name="keywords" content="Daryl, Daryl Farber, Daryl Färber, darylfarber, php, laravel, react, portfolio">
			<meta name="author" content="Daryl Farber">
			<meta property="og:title" content="Daryl Färber - Personal Website | darylfarber.nl">
			<meta property="og:description" content="Full-stack developer met focus op Laravel, React en moderne webapps.">
			<meta property="og:url" content="https://darylfarber.nl/">
			<meta property="og:image" content="https://darylfarber.nl/assets/images/me.png">
			<script src="https://cdn.tailwindcss.com"></script>
			<link rel="stylesheet" href="./assets/css/style.css?{{ " now"|date(" sdi") }}">
			<link rel="shortcut icon" href="./assets/images/favicon.png?v=1" type="image/x-icon">
			<script src="https://kit.fontawesome.com/4672461ce1.js" crossorigin="anonymous"></script>
			<title>
				Daryl Färber:
				{% block title %}{% endblock %}
			</title>
		{% endblock %}
	</head>
	<body class="min-h-screen overflow-x-hidden bg-slate-950 text-slate-100 antialiased">
		<div id="circle" aria-hidden="true"></div>
		<nav class="sticky top-0 z-30 border-b border-slate-800/80 bg-slate-950/95 backdrop-blur supports-[backdrop-filter]:bg-slate-950/80">
			<div class="mx-auto w-full max-w-6xl px-4 sm:px-6">
				<div class="flex items-center justify-between gap-4 py-3 sm:py-4">
					<a class="flex min-h-[44px] items-center text-lg font-semibold tracking-wide text-white [-webkit-tap-highlight-color:transparent]" href="/">Daryl F.</a>
					<button type="button" id="nav-toggle" class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-lg border border-slate-700/80 bg-slate-900/80 text-slate-200 md:hidden [-webkit-tap-highlight-color:transparent]" aria-controls="nav-mobile" aria-expanded="false" aria-label="Menu openen">
						<i class="fa-solid fa-bars text-lg" aria-hidden="true"></i>
					</button>
					<div class="hidden flex-wrap items-center justify-end gap-1 md:flex">
						<a class="nav-link-modern {% if page == "home" %}nav-link-active{% endif %}" href="/">
							<i class="fa-solid fa-house"></i>
							<span>Home</span>
						</a>
						<a class="nav-link-modern {% if page == "projects" %}nav-link-active{% endif %}" href="/projects">
							<i class="fa-solid fa-diagram-project"></i>
							<span>Projecten</span>
						</a>
						<a class="nav-link-modern {% if page == "contact" %}nav-link-active{% endif %}" href="/contact">
							<i class="fa-solid fa-address-card"></i>
							<span>Contact</span>
						</a>
						{% if gebruiker is defined %}
							<a class="nav-link-modern" href="/school">
								<i class="fa-solid fa-graduation-cap"></i>
								<span>School</span>
							</a>
							<a class="nav-link-modern" href="/logout">
								<i class="fa-solid fa-right-from-bracket"></i>
								<span>Uitloggen</span>
							</a>
						{% endif %}
					</div>
				</div>
				<div id="nav-mobile" class="nav-mobile-panel hidden flex flex-col border-t border-slate-800/80 pb-3 md:hidden">
					<div class="flex flex-col gap-0.5 pt-2">
						<a class="nav-link-mobile {% if page == "home" %}nav-link-mobile-active{% endif %}" href="/">
							<i class="fa-solid fa-house w-5 shrink-0"></i>
							<span>Home</span>
						</a>
						<a class="nav-link-mobile {% if page == "projects" %}nav-link-mobile-active{% endif %}" href="/projects">
							<i class="fa-solid fa-diagram-project w-5 shrink-0"></i>
							<span>Projecten</span>
						</a>
						<a class="nav-link-mobile {% if page == "contact" %}nav-link-mobile-active{% endif %}" href="/contact">
							<i class="fa-solid fa-address-card w-5 shrink-0"></i>
							<span>Contact</span>
						</a>
						{% if gebruiker is defined %}
							<a class="nav-link-mobile" href="/school">
								<i class="fa-solid fa-graduation-cap w-5 shrink-0"></i>
								<span>School</span>
							</a>
							<a class="nav-link-mobile" href="/logout">
								<i class="fa-solid fa-right-from-bracket w-5 shrink-0"></i>
								<span>Uitloggen</span>
							</a>
						{% endif %}
					</div>
				</div>
			</div>
		</nav>
		<main class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6 sm:py-8">
			{% if error is defined %}
				<div class="mb-6 rounded-2xl border border-red-400/30 bg-red-500/10 p-4 text-red-100">
					<div class="flex items-start gap-3">
						<i class="fa-solid fa-triangle-exclamation mt-1 text-lg"></i>
						<p><strong>Error:</strong> {{ error }}</p>
					</div>
				</div>
			{% endif %}

			{% block body %}{% endblock %}
		</main>
		<footer class="border-t border-slate-800/80 py-6 pb-[max(1.5rem,env(safe-area-inset-bottom))]">
			<div class="mx-auto flex w-full max-w-6xl flex-col items-start justify-between gap-4 px-4 sm:flex-row sm:items-center sm:px-6">
				<div>
					<div class="mb-2 flex items-center gap-4 text-2xl">
						<a href="https://github.com/darylfrber" target="_blank" rel="noreferrer" class="text-slate-300 transition hover:text-white">
							<i class="fa-brands fa-github"></i>
						</a>
						<a href="https://www.linkedin.com/in/daryl-farber" target="_blank" rel="noreferrer" class="text-slate-300 transition hover:text-white">
							<i class="fa-brands fa-linkedin"></i>
						</a>
					</div>
					<p class="text-sm text-slate-400">Gemaakt door Daryl Färber</p>
				</div>
				<p class="text-sm text-slate-500">© DARYLFARBER.NL - 2026</p>
			</div>
		</footer>
		<script src="./assets/js/script.js?{{ " now"|date(" sdi") }}"></script>
	</body>
</html>